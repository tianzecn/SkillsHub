{
  "name": "@prompthub/desktop",
  "version": "0.5.9",
  "private": true,
  "description": "PromptHub Desktop - Electron application for AI prompt management",
  "main": "out/main/index.js",
  "bin": {
    "prompthub": "bin/prompthub.cjs"
  },
  "exports": {
    ".": "./out/cli/prompthub.cjs"
  },
  "files": [
    "bin",
    "out/cli",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "author": {
    "name": "legeling",
    "email": "legeling567@gmail.com",
    "url": "https://github.com/legeling"
  },
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/tianzecn/SkillsHub.git",
    "directory": "apps/desktop"
  },
  "scripts": {
    "dev": "vite",
    "cli:dev": "tsx src/cli/index.ts",
    "cli:build": "vite build --config vite.cli.config.ts",
    "prepare": "vite build --config vite.cli.config.ts",
    "prepack": "vite build --config vite.cli.config.ts",
    "dev:web": "vite --config vite.web.config.ts",
    "build": "vite build && vite build --config vite.cli.config.ts",
    "preview": "vite preview",
    "electron:dev": "vite",
    "electron:build": "vite build && vite build --config vite.cli.config.ts && electron-builder",
    "electron:build:mac": "vite build && vite build --config vite.cli.config.ts && electron-builder --mac --x64 --arm64 --publish never",
    "electron:build:win": "vite build && vite build --config vite.cli.config.ts && electron-builder --win --x64 --arm64 --publish never",
    "electron:build:linux": "vite build && vite build --config vite.cli.config.ts && electron-builder --linux --x64 --publish never",
    "lint": "eslint . --ext ts,tsx,mts --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "test": "vitest",
    "test:cli": "vitest run tests/unit/cli/run.test.ts",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:i18n": "vitest run tests/unit/services/skill-locale-regression.test.ts tests/unit/components/skill-detail-utils.test.ts tests/unit/components/skill-i18n-smoke.test.tsx tests/unit/services/i18n-init.test.ts tests/unit/stores/settings-language.test.ts",
    "test:run": "vitest run",
    "test:coverage": "vitest --coverage",
    "test:perf": "pnpm perf:budget",
    "test:e2e": "pnpm build && playwright test",
    "test:e2e:smoke": "pnpm build && playwright test tests/e2e/app.spec.ts tests/e2e/self-hosted-sync.spec.ts",
    "test:release": "pnpm lint && pnpm typecheck && pnpm test:unit && pnpm test:integration && pnpm build && pnpm test:e2e:smoke",
    "typecheck": "tsc --noEmit",
    "perf:large-data": "node --experimental-strip-types scripts/profile-large-datasets.mts",
    "perf:large-data:heavy": "node --experimental-strip-types scripts/profile-large-datasets.mts --prompts=5000 --skills=2000 --iterations=20",
    "perf:budget": "node --experimental-strip-types scripts/check-large-data-budgets.mts",
    "perf:budget:ci": "node --experimental-strip-types scripts/profile-large-datasets.mts --prompts=5000 --skills=2000 --iterations=20"
  },
  "dependencies": {
    "node-sqlite3-wasm": "^0.8.0"
  },
  "devDependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@playwright/test": "^1.57.0",
    "@prompthub/db": "workspace:*",
    "@prompthub/shared": "workspace:*",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/react-window": "^2.0.0",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^2.0.0",
    "autoprefixer": "^10.4.22",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "concurrently": "^9.0.0",
    "electron": "33",
    "electron-builder": "^25.0.0",
    "electron-updater": "^6.6.2",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "fflate": "^0.8.2",
    "framer-motion": "^12.26.1",
    "hast-util-sanitize": "^5.0.0",
    "highlight.js": "^11.8.0",
    "i18next": "^24.0.0",
    "jsdom": "^27.3.0",
    "lucide-react": "^0.460.0",
    "playwright": "^1.57.0",
    "postcss": "^8.4.49",
    "prettier": "^3.4.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-i18next": "^15.0.0",
    "react-window": "^2.2.7",
    "react-markdown": "^9.0.0",
    "rehype-highlight": "^6.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.0",
    "tailwind-merge": "^2.5.0",
    "tailwindcss": "^3.4.15",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.20.3",
    "typescript": "^5.6.0",
    "uuid": "^13.0.0",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^2.0.0",
    "wait-on": "^8.0.0",
    "zustand": "^5.0.0"
  }
}
